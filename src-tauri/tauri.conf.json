{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "picode",
  "version": "0.1.3",
  "identifier": "dev.pi.picode",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "backgroundColor": "#121212",
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 21
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/picode-icon-dark.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "targets": ["dmg", "appimage", "deb", "rpm"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdERkFBMUI2MUUxNDIyRjIKUldUeUloUWV0cUg2ZmVEbzNTcEE1ODUweW9kUjVLWVdrUzZ6N0UxbTBRZ2Jpc01CT0JXNTFoS2UK",
      "endpoints": [
        "https://github.com/VOID229/picode/releases/latest/download/latest.json"
      ]
    }
  }
}
