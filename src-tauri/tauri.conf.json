{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "picode",
  "version": "0.1.0",
  "identifier": "dev.pi.picode",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "picode",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb", "rpm"],
    "externalBin": ["bin/pi-sidecar"]
  }
}
