#!/usr/bin/env bash
set -euo pipefail

decode_base64() {
  if base64 --help 2>&1 | grep -q '\-d'; then
    printf '%s' "$1" | base64 -d
  else
    printf '%s' "$1" | base64 -D
  fi
}

while IFS=$'\t' read -r action session_id provider_id model_id prompt_b64; do
  if [ "$action" != "send" ]; then
    continue
  fi

  prompt="$(decode_base64 "$prompt_b64")"
  short_prompt="$(printf '%s' "$prompt" | cut -c1-72)"

  cat <<EOF
{"type":"status","label":"Connecting to bundled Pi runtime","detail":"$provider_id / $model_id"}
EOF
  sleep 0.08

  started_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  cat <<EOF
{"type":"tool-start","activity":{"id":"tool-$session_id","tool_name":"workspace_scan","summary":"Inspecting git and workspace state before taking action.","output":null,"status":"running","started_at":"$started_at"}}
EOF
  sleep 0.12

  cat <<EOF
{"type":"tool-output","activity_id":"tool-$session_id","output":"Detected workspace context, active branch, and session policy. Preparing an approval gate for the next mutating step.","status":"completed"}
EOF
  sleep 0.12

  requested_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  cat <<EOF
{"type":"approval-requested","approval":{"id":"approval-$session_id","title":"Run a mutating workspace command","reason":"Pi wants permission to make a filesystem or git mutation in Ask First mode.","command":"git status --short --branch && git diff --stat","path":null,"diff_preview":"--- a/src/example.ts\n+++ b/src/example.ts\n@@\n- old\n+ new","risk":"medium","status":"pending","requested_at":"$requested_at"}}
EOF
  sleep 0.12

  token_chunks=(
    "Planning the workspace pass. "
    "I inspected the active repo, policy envelope, and recent session history. "
    "Next I would stage the concrete changes needed for: $short_prompt. "
    "Once approval clears, I can continue with file mutations and a tighter diff. "
  )

  for chunk in "${token_chunks[@]}"; do
    printf '{"type":"token","delta":"%s"}\n' "$chunk"
    sleep 0.07
  done

  final_content="Planning the workspace pass. I inspected the active repo, policy envelope, and recent session history. Next I would stage the concrete changes needed for: $short_prompt. Once approval clears, I can continue with file mutations and a tighter diff."
  printf '{"type":"done","content":"%s"}\n' "$final_content"
done
